+
+$arrUnRAIDVersions = [];
+$rawJson = @file_get_contents('https://releases.unraid.net/usb-creator');
+if ($rawJson !== false) {
+    $decoded = json_decode($rawJson, true);
+    if (is_array($decoded) && isset($decoded['os_list'])) {
+        $flat = array_merge(...array_map(
+            fn($os) => $os['subitems'] ?? [$os],
+            $decoded['os_list']
+        ));
+        $arrUnRAIDVersions = array_column(
+            array_map(
+                fn($item) => [
+                    'name'      => substr($item['name'], 7),
+                    'url'       => $item['url'],
+                    'size'      => $item['image_download_size'],
+                    'localpath' => '',
+                    'valid'     => 0
+                ],
+                array_filter($flat, fn($item) => $item['name'] !== 'Unraid OS Releases (Next Branch)')
+            ),
+            null,
+            'name'
+        );
+        uksort($arrUnRAIDVersions, fn($a, $b) => version_compare($b, $a));
+    }
+}
